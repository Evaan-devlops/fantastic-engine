# Runtime command queue generated on the Mac
SOP/runtime/commands/*
!SOP/runtime/commands/.gitkeep
SOP/runtime/acknowledgements/*
!SOP/runtime/acknowledgements/.gitkeep
SOP/runtime/processed/*
!SOP/runtime/processed/.gitkeep
SOP/runtime/failed/*
!SOP/runtime/failed/.gitkeep

# Runtime runs and evidence, machine/user specific
SOP/runs/*
!SOP/runs/.gitkeep

# Learned runtime corrections and routes generated during real execution
SOP/resolutions/*
!SOP/resolutions/.gitkeep
SOP/routes/*
!SOP/routes/.gitkeep

# Generated SOP compilation artifacts reproducible from preserved SOP sources
SOP/compiled/*
!SOP/compiled/.gitkeep
SOP/manifests/*
!SOP/manifests/.gitkeep
SOP/generated/*
!SOP/generated/.gitkeep

# Temporary incoming task/SOP files
SOP/inbox/*
!SOP/inbox/.gitkeep
!SOP/inbox/README.md

# Tool-build runtime requests and results
SOP/tool_build_requests/*
!SOP/tool_build_requests/.gitkeep
SOP/tool_build_results/*
!SOP/tool_build_results/.gitkeep

# Local SQLite/database files
*.db
*.sqlite
*.sqlite3
*.db-journal

# Local archives and package copies
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# Claude/Codex coding prompts accidentally placed in product
Claude_*.txt
Codex_*.txt
*_Coding_Prompt.txt
*_Correction_Prompt.txt
